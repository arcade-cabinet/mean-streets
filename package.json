{
  "name": "mean-streets",
  "private": true,
  "version": "0.1.0",
  "description": "Mean Streets: Precision Starvation — A gritty tactical 1v1 card brawler",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sim": "tsx src/sim/main.ts",
    "sim:balance": "tsx src/sim/main.ts --sweep balance",
    "sim:explore": "tsx src/sim/main.ts --sweep all",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "koota": "^0.6.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yuka": "^0.7.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
